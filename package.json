{
  "name": "healthycal-react",
  "version": "1.0.0",
  "description": "HealthyCal - Mindful Eating React Application",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "start": "npm run dev:all",
    "test:unit": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest",
    "test:e2e": "cypress run",
    "test": "start-server-and-test start http://localhost:5173 test:e2e && npm run test:unit"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/server/tests"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^9.2.1",
    "cypress": "^15.7.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "start-server-and-test": "^2.1.3",
    "supertest": "^7.1.4",
    "vite": "^5.0.8"
  }
}